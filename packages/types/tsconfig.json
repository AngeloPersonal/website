{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "Bundler",
		"declaration": true,
		"emitDeclarationOnly": false,
		"outDir": "dist",
		"strict": true,
		"skipLibCheck": true
	},
	"include": [
		"src/**/*.ts", 
		"index.ts", 
		"src/generated.ts"
	],
	"exclude": ["node_modules"]
}